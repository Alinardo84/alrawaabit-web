# AlRawaabit Website - Environment Variables
# Copy this file to .env.local and fill in your values

# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=your_api_token_here
SANITY_PREVIEW_SECRET=your_random_preview_secret_here
SANITY_REVALIDATE_SECRET=your_random_revalidate_secret_here

# Resend (Contact Form Emails)
RESEND_API_KEY=re_xxxxxxxxxxxxx

# Site URL
NEXT_PUBLIC_SITE_URL=https://alrawaabit.com

# Studio URL — where /studio redirects to (Vercel project or sanity.studio)
NEXT_PUBLIC_STUDIO_URL=https://alrawaabit.sanity.studio