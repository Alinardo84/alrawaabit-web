# AlRawaabit Website - Environment Variables
# Copy this file to .env.local and fill in your values

# Resend (Contact Form Emails)
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxx

# Site URL (for sitemap, OG images, etc.)
NEXT_PUBLIC_SITE_URL=https://alrawaabit.com

# Higgsfield AI (Optional - for media generation)
# Get from: https://higgsfield.ai after auth login
# HIGGSFIELD_API_KEY=hf_xxxxxxxxxxxxx

# Analytics (Optional - Vercel Analytics is automatic)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX